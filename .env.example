# ============================
# Original MCPAgents API Keys
# ============================
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
GOOGLE_API_KEY=your_google_api_key

# ============================
# NEW: Splunk Integration
# ============================

# ① HEC Telemetry Emitter
SPLUNK_HEC_URL=http://localhost:8088
SPLUNK_HEC_TOKEN=your-hec-token-here
SPLUNK_HEC_INDEX=mcp_agents

# ② Splunk MCP Server (GA 2026)
SPLUNK_MCP_SERVER_URL=https://your-splunk-instance.splunkcloud.com/mcp
SPLUNK_MCP_TOKEN=your-mcp-server-token

# ③ Splunk REST API (for direct SPL queries)
SPLUNK_API_URL=https://your-splunk-instance.splunkcloud.com:8089
SPLUNK_API_TOKEN=your-splunk-api-token
SPLUNK_USERNAME=admin
SPLUNK_PASSWORD=your-splunk-password

# ③ Splunk SOAR (Security Orchestration)
SPLUNK_SOAR_URL=https://your-soar-instance.splunkcloud.com
SPLUNK_SOAR_TOKEN=your-soar-token

# ④ Foundation-sec Model (Security PII scoring)
SPLUNK_FOUNDATION_SEC_URL=https://api.splunk.com/2.0/rest/foundation-sec/chat/completions

# ④ Auto-Remediation Webhook
MCPAGENTS_WEBHOOK_URL=http://localhost:8000
MCPAGENTS_WEBHOOK_PORT=8000

# Redis (Semantic Cache)
REDIS_URL=redis://localhost:6379

# ============================
# NEW: Supabase MCP (cumulative visitors analytics)
# ============================
# Backend agent tool `supabase_query`. If URL+KEY unset, the tool returns
# simulated demo values (app still works on Streamlit Cloud Demo Mode).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key
# Optional override (default shown) — total row count = cumulative visitors:
SUPABASE_VISITORS_TABLE=visitors
